<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient_auth"
    tools:context=".ui.auth.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >


    <!-- Top spacer to push content down (teal area) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_weight="1" />


    <!--    Title -->

    <TextView
        android:id="@+id/tvSignInTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign in"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingBottom="24dp" />

    <!-- Bottom black section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="52dp">


        <!-- Email Input -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxStrokeWidth="0dp"
            app:boxBackgroundColor="#000"
            app:boxStrokeWidthFocused="0dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:hintEnabled="false"
            app:hintTextColor="@color/white">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="#888888"
                android:textColor="@color/white"
                android:inputType="textEmailAddress"
                android:hint="Email" />

        </com.google.android.material.textfield.TextInputLayout>


        <!-- Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundColor="#000"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#888888">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Password"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="16sp"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Sign In Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="59dp"
            android:layout_marginTop="26dp"
            android:text="Sign in"
            android:textColor="#000000"
            android:textSize="19sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Forgot your login or password?"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

        <!-- Create Account Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateAccount"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:text="Create account"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingHorizontal="24dp"
            app:backgroundTint="#2A2A2A"
            app:cornerRadius="22dp"
            app:elevation="0dp" />

        <!-- Pricing Text -->
        <TextView
            android:id="@+id/tvPricing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Free for 3 months, then $12 a month"
            android:textColor="#666666"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>



    </LinearLayout>

</ScrollView>